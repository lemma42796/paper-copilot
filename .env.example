# OpenAI-compatible endpoint for the LLM backend.
# Default target: 阿里云百炼 (DashScope) compatible-mode endpoint.
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL=qwen3.6-flash

# API key for the endpoint above. For Dashscope, get one at
# https://bailian.console.aliyun.com/ -> API-KEY.
LLM_API_KEY=sk-your-key-here

# DashScope embedding key. Remove this line to fall back to LLM_API_KEY when
# the LLM also uses DashScope.
DASHSCOPE_API_KEY=sk-your-key-here

# Default local PDF library used by chat/research when no pdf_dir is passed.
# On this workstation the default fallback is /Users/a123/paper-copilot-test-pdfs.
PAPER_COPILOT_PDF_DIR=/Users/a123/paper-copilot-test-pdfs
